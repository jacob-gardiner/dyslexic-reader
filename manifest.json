{
  "manifest_version": 3,
  "name": "Dyslexic Reader",
  "version": "1.0",
  "description": "Replace all web fonts with OpenDyslexic",
  "permissions": ["storage", "activeTab", "scripting", "notifications"],
  "content_scripts": [
    {
      "js": ["scripts/content.js"],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_popup": "./popup.html"
  }
}